<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="seriesjpa_test" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Genero</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Serie</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Usuario</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Valoracion</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:mem:seriesdb;DB_CLOSE_DELAY=-1"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
    <persistence-unit name="seriesjpa_dev" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Genero</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Serie</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Usuario</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Valoracion</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:./data/seriesdb"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
    <persistence-unit name="seriesjpa_prod" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Genero</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Serie</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Usuario</class>
        <class>org.zabalburu.seriesjpa.tmdb.modelo.Valoracion</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="oracle.jdbc.OracleDriver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:oracle:thin:@localhost:1521/XE"/>
            <property name="jakarta.persistence.jdbc.user" value="CAMBIAR_USUARIO"/>
            <property name="jakarta.persistence.jdbc.password" value="CAMBIAR_PASSWORD"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.OracleDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

  
</persistence>
